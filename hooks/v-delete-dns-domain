#!/bin/bash
# =============================================================================
# HestiaCP → Bunny DNS  –  Hook: v-delete-dns-domain
# /usr/local/hestia/data/hooks/v-delete-dns-domain
# https://komorebihost.com
#
# Called by HestiaCP after a DNS-only zone is deleted.
# Args: USER DOMAIN [RESTART]
# =============================================================================

USER="$1"
DOMAIN="$2"

[ -z "$USER" ] || [ -z "$DOMAIN" ] && exit 0

ENGINE="/usr/local/hestia/plugins/bunny-dns/bunny-dns.sh"
[ -x "$ENGINE" ] || exit 0

"$ENGINE" delete "$DOMAIN" "$USER" &
exit 0
